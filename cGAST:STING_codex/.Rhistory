ggsave(out_png, left, width = 9.8, height = 10, dpi = 300)
ggsave(out_pdf, left, width = 9.8, height = 10)
message("Saved RNA-seq heatmap: ", out_png, " and ", out_pdf)
}
make_composite <- function(dat_plot, value_col, title_suffix, right_panel_grob, out_png, out_pdf){
heat <- make_heatmap(dat_plot, value_col, paste0(title_suffix, " (RNA-seq)"))
left <- cowplot::plot_grid(make_somite_ruler(xmin = 24, xmax = 49), heat, ncol = 1,
rel_heights = c(0.55, 1), align = "v")
combo <- cowplot::plot_grid(left, right_panel_grob, nrow = 1, rel_widths = c(1.05, 1.15), align = "h")
ggsave(out_png, combo, width = 16.5, height = 10, dpi = 300)
ggsave(out_pdf, combo, width = 16.5, height = 10)
message("Saved COMPOSITE: ", out_png, " and ", out_pdf)
}
# RNA-seq only
if (nrow(dat_raw)) {
make_heatmap_combo(dat_raw, "log2FC_raw", "RAW log2FC", out_png_raw, out_pdf_raw)
}
if (nrow(dat_shr)) {
make_heatmap_combo(dat_shr, "log2FC_shrunken", "Shrunken log2FC", out_png_shrunken, out_pdf_shrunken)
}
# Standalone PCR (show-all)
pcr_tiles_plot  <- make_pcr_tiles(pcr_long_union)
pcr_lolli_plot  <- make_pcr_lollipops(pcr_long_union)
ggsave(out_pcr_tiles_png, pcr_tiles_plot, width = 10.5, height = 10, dpi = 300)
ggsave(out_pcr_tiles_pdf, pcr_tiles_plot, width = 10.5, height = 10)
ggsave(out_pcr_lolli_png, pcr_lolli_plot, width = 10.5, height = 10, dpi = 300)
ggsave(out_pcr_lolli_pdf, pcr_lolli_plot, width = 10.5, height = 10)
# Composites — Matching-only PCR
if (nrow(dat_raw)) {
make_composite(dat_raw, "log2FC_raw", "RAW log2FC",
make_pcr_tiles(pcr_long_match), out_combo_raw_tiles_png, out_combo_raw_tiles_pdf)
make_composite(dat_raw, "log2FC_raw", "RAW log2FC",
make_pcr_lollipops(pcr_long_match), out_combo_raw_lolli_png, out_combo_raw_lolli_pdf)
}
if (nrow(dat_shr)) {
make_composite(dat_shr, "log2FC_shrunken", "SHRUNKEN log2FC",
make_pcr_tiles(pcr_long_match), out_combo_shr_tiles_png, out_combo_shr_tiles_pdf)
make_composite(dat_shr, "log2FC_shrunken", "SHRUNKEN log2FC",
make_pcr_lollipops(pcr_long_match), out_combo_shr_lolli_png, out_combo_shr_lolli_pdf)
}
# Composites — Show-all PCR (RNA-seq padded to union)
if (nrow(dat_raw_union)) {
make_composite(dat_raw_union, "log2FC_raw", "RAW log2FC",
make_pcr_tiles(pcr_long_union), out_combo_raw_tiles_all_png, out_combo_raw_tiles_all_pdf)
make_composite(dat_raw_union, "log2FC_raw", "RAW log2FC",
make_pcr_lollipops(pcr_long_union), out_combo_raw_lolli_all_png, out_combo_raw_lolli_all_pdf)
}
if (nrow(dat_shr_union)) {
make_composite(dat_shr_union, "log2FC_shrunken", "SHRUNKEN log2FC",
make_pcr_tiles(pcr_long_union), out_combo_shr_tiles_all_png, out_combo_shr_tiles_all_pdf)
make_composite(dat_shr_union, "log2FC_shrunken", "SHRUNKEN log2FC",
make_pcr_lollipops(pcr_long_union), out_combo_shr_lolli_all_png, out_combo_shr_lolli_all_pdf)
}
# =========================
# 7) Volcano plots (RAW vs SHRUNKEN) + Rank-change tables
# =========================
volcano_dir <- file.path(out_dir, "volcano_raw_vs_shrunken")
dir.create(volcano_dir, showWarnings = FALSE, recursive = TRUE)
alpha_sig     <- 0.05
lfc_min_label <- 1.0
p_floor       <- 1e-300
pt_size       <- 1.2
prep_volcano_df <- function(df_all_genes_one_contrast, lfc_col){
stopifnot(lfc_col %in% names(df_all_genes_one_contrast))
df_all_genes_one_contrast %>%
transmute(
gene    = gene,
contrast= contrast,
lfc     = suppressWarnings(as.numeric(.data[[lfc_col]])),
padj    = suppressWarnings(as.numeric(padj))
) %>%
filter(!is.na(lfc), !is.na(padj)) %>%
mutate(
neglog10padj = -log10(pmax(padj, p_floor)),
sig     = padj <= alpha_sig,
bigEff  = abs(lfc) >= lfc_min_label,
quad    = case_when(
sig & bigEff  ~ "sig & |LFC|≥1",
sig & !bigEff ~ "sig only",
!sig & bigEff ~ "|LFC|≥1 only",
TRUE          ~ "other"
),
quad = factor(quad, levels = c("sig & |LFC|≥1","sig only","|LFC|≥1 only","other"))
)
}
make_volcano <- function(df_volcano, title){
ggplot(df_volcano, aes(x = lfc, y = neglog10padj)) +
geom_hline(yintercept = -log10(alpha_sig), color = "grey85", linewidth = 0.3) +
geom_vline(xintercept = c(-lfc_min_label, lfc_min_label), color = "grey90", linewidth = 0.3) +
geom_point(aes(shape = bigEff, alpha = sig, fill = quad),
size = pt_size, stroke = 0.1, color="grey25", pch = 21) +
scale_alpha_manual(values = c(`TRUE`=0.9, `FALSE`=0.5), guide = "none") +
scale_shape_manual(values = c(`TRUE`=21, `FALSE`=21), guide = "none") +
scale_fill_manual(
values = c("sig & |LFC|≥1"="#d73027", "sig only"="#fc8d59",
"|LFC|≥1 only"="#91bfdb", "other"="#d9d9d9"),
name = NULL, drop = FALSE
) +
labs(x = "log2 fold change", y = expression(-log[10]("adj. p")),
title = title) +
theme_minimal(base_size = 11) +
theme(panel.grid.minor = element_blank(),
plot.title = element_text(face = "bold"))
}
rank_change_table <- function(df_raw, df_shr){
R <- df_raw  %>% select(gene, contrast, lfc_raw  = lfc, padj_raw = padj) %>%
group_by(contrast) %>% mutate(rank_abs_raw = rank(-abs(lfc_raw), ties.method = "average")) %>% ungroup()
S <- df_shr  %>% select(gene, contrast, lfc_shr  = lfc, padj_shr = padj) %>%
group_by(contrast) %>% mutate(rank_abs_shr = rank(-abs(lfc_shr), ties.method = "average")) %>% ungroup()
R %>% inner_join(S, by = c("gene","contrast")) %>%
mutate(
delta_rank = rank_abs_raw - rank_abs_shr,   # +: moved up after shrink
abs_delta  = abs(delta_rank),
dir_raw = ifelse(lfc_raw >= 0, "up", "down"),
dir_shr = ifelse(lfc_shr >= 0, "up", "down"),
flip_dir = dir_raw != dir_shr
) %>%
arrange(desc(abs_delta))
}
all_contrasts <- unique(dat_all$contrast)
rankchange_list <- list()
for (ct in all_contrasts) {
df_ct <- dat_all %>% filter(contrast == ct)
has_raw <- "log2FC_raw"      %in% names(df_ct) && any(!is.na(df_ct$log2FC_raw))
has_shr <- "log2FC_shrunken" %in% names(df_ct) && any(!is.na(df_ct$log2FC_shrunken))
if (!has_raw && !has_shr) { message("Skipping: ", ct); next }
if (has_raw) {
v_raw <- prep_volcano_df(df_ct, "log2FC_raw")
p_raw <- make_volcano(v_raw, paste0(ct, " — RAW LFC"))
} else { v_raw <- NULL; p_raw <- ggplot() + theme_void() + labs(title=paste0(ct," — RAW LFC (NA)")) }
if (has_shr) {
v_shr <- prep_volcano_df(df_ct, "log2FC_shrunken")
p_shr <- make_volcano(v_shr, paste0(ct, " — SHRUNKEN LFC"))
} else { v_shr <- NULL; p_shr <- ggplot() + theme_void() + labs(title=paste0(ct," — SHRUNKEN LFC (NA)")) }
pair <- cowplot::plot_grid(p_raw, p_shr, nrow = 1, rel_widths = c(1,1), align = "h")
f_png <- file.path(volcano_dir, paste0("VOLCANO_PAIR__", gsub("[^A-Za-z0-9_-]+","_", ct), ".png"))
f_pdf <- file.path(volcano_dir, paste0("VOLCANO_PAIR__", gsub("[^A-Za-z0-9_-]+","_", ct), ".pdf"))
ggsave(f_png, pair, width = 12, height = 5.8, dpi = 300)
ggsave(f_pdf, pair, width = 12, height = 5.8)
if (!is.null(v_raw) && !is.null(v_shr)) {
rc <- rank_change_table(v_raw, v_shr)
rankchange_list[[ct]] <- rc
utils::write.csv(head(rc, 100),
file = file.path(volcano_dir, paste0("RANKCHANGE_top100__", gsub("[^A-Za-z0-9_-]+","_", ct), ".csv")),
row.names = FALSE
)
}
}
if (length(rankchange_list)) {
rankchange_all <- dplyr::bind_rows(rankchange_list, .id = "contrast_id") %>%
arrange(desc(abs_delta))
utils::write.csv(rankchange_all,
file = file.path(volcano_dir, "RANKCHANGE_allContrasts_full.csv"),
row.names = FALSE
)
utils::write.csv(head(rankchange_all, 200),
file = file.path(volcano_dir, "RANKCHANGE_allContrasts_top200.csv"),
row.names = FALSE
)
message("Volcanoes & rank-change tables written to: ", volcano_dir)
} else {
message("No rank-change tables produced (need both RAW and SHRUNKEN LFCs).")
}
# =========================
# 8) PCR (VERTICAL) — somite map left; tiles right (A9→…→D13)
#     PADDED to include full tiles down to 42
#     PCR-only axes are bold/larger; white tile borders
# =========================
pcr_vert_dir <- file.path(out_dir, "PCR_vertical")
dir.create(pcr_vert_dir, showWarnings = FALSE, recursive = TRUE)
make_pcr_ruler_vertical <- function(df_pcr){
ymin <- min(df_pcr$somite, na.rm = TRUE)
ymax <- max(df_pcr$somite, na.rm = TRUE)
df_band <- band_df(xmin = ymin, xmax = ymax, by = 0.5)
ggplot(df_band, aes(x = 1, y = x, fill = group)) +
geom_tile(width = 0.9, height = 0.5, color = "white", linewidth = 0.2, na.rm = TRUE) +
scale_y_reverse(breaks = seq(ymin, ymax, 1), limits = c(ymax, ymin), expand = c(0, 0)) +
scale_x_continuous(expand = c(0, 0)) +
scale_fill_manual(
values = somite_band_cols,
breaks = names(somite_band_cols),
limits = names(somite_band_cols),
name   = "Somite band",
drop = FALSE, na.translate = FALSE
) +
labs(x = NULL, y = "Somite", title = "Somite map (vertical)") +
theme_minimal(base_size = 10) +
theme(axis.text.x  = element_blank(), axis.title.x = element_blank(),
panel.grid   = element_blank(), legend.position = "top",
plot.title = element_text(size = 11, face = "bold"))
}
make_pcr_tiles_vertical <- function(df_pcr){
ymin <- floor(min(df_pcr$somite, na.rm = TRUE))
ymax <- ceiling(max(df_pcr$somite, na.rm = TRUE))
ymax_plot <- max(42, ymax)
levels_x <- compute_hox_x_levels(df_pcr$row_label)
df_pcr <- df_pcr %>% mutate(row_label = factor(row_label, levels = levels_x))
ggplot(df_pcr, aes(x = row_label, y = somite, fill = level)) +
geom_tile(color = "white", linewidth = 0.4, height = 0.92, width = 0.92) +
scale_y_reverse(
breaks = seq(ymin, ymax_plot, 1),
limits = c(ymax_plot + 0.5, ymin - 0.5),
expand  = c(0, 0)
) +
scale_fill_manual(values = lvl_fill, drop = FALSE, name = "RT-qPCR\n(x / + / ++)") +
guides(fill = guide_legend(override.aes = list(color = NA))) +
labs(x = NULL, y = "Somite", title = "HOX — RT-qPCR tiles (vertical)") +
theme_minimal(base_size = 11) +
theme(
panel.grid  = element_blank(),
plot.title  = element_text(face = "bold"),
axis.text.x = element_text(size = gene_axis_text_size,   face = "bold", angle = 45, hjust = 1),
axis.text.y = element_text(size = somite_axis_text_size, face = "bold")
)
}
# Composite: somite map (left) + tiles (right)
