# =========================
# 10) Hox (y) vs Somite (x) BAR MAP (only + / ++, optional reversed y)
# =========================
make_pcr_hox_bar <- function(df_pcr){
if (!nrow(df_pcr)) {
return(ggplot() + theme_void() + labs(title = "No PCR data"))
}
# Choose factor order for this plot (optionally reversed)
levels_for_bar <- if (isTRUE(hox_bar_reverse_y)) rev(row_levels_union) else row_levels_union
# Contiguous somite runs per gene, ONLY when level is + or ++
df_seg <- df_pcr %>%
filter(!is.na(level), level %in% c("+","++")) %>%   # + / ++ only
mutate(
row_label = factor(row_label, levels = levels_for_bar),
somite    = as.integer(somite)
) %>%
arrange(row_label, somite) %>%
group_by(row_label) %>%
mutate(
run_id = cumsum(
if_else(row_number() == 1L | somite - lag(somite) != 1L, 1L, 0L)
)
) %>%
group_by(row_label, run_id) %>%
summarise(
somite_start = min(somite),
somite_end   = max(somite),
# highest level in the run (+ or ++)
max_level    = level[which.max(as.numeric(level))],
.groups = "drop"
)
if (!nrow(df_seg)) {
return(ggplot() + theme_void() + labs(title = "No +/++ PCR signal"))
}
xmin <- min(df_seg$somite_start, na.rm = TRUE)
xmax <- max(df_seg$somite_end,   na.rm = TRUE)
xmax_plot <- max(42, xmax)
# Color ramp along Hox axis (match current y order)
hox_labels <- levels_for_bar
hox_cols <- colorRampPalette(
#c("#a1d99b", "#f03b20", "#fee391", "#fdae6b", "#2166AC" )
#ONLY NEED ONE OF THESE: BOTTOM IS FOR REVERSED = TRUE above
#LINE 67 hox_bar_reverse_y <- FALSE
c("#2166AC", "#fdae6b", "#fee391", "#f03b20", "#a1d99b")
)(length(hox_labels))
names(hox_cols) <- hox_labels
# Line thickness by level
lvl_width_bar <- c("+" = 3.0, "++" = 4.5)
ggplot(df_seg, aes(y = row_label)) +
geom_segment(
aes(x = somite_start,
xend = somite_end,
color = row_label,
size = max_level),
lineend = "round"
) +
scale_x_continuous(
breaks = seq(xmin, xmax_plot, 1),
limits = c(xmin - 0.5, xmax_plot + 0.5),
expand = expansion(mult = c(0.02, 0.02)),
name   = "Somite"
) +
scale_color_manual(values = hox_cols, guide = "none") +
scale_size_manual(values = lvl_width_bar, guide = "none") +
labs(
y     = "Hox gene",
title = "Hox expression domains by somite (RT-qPCR; + / ++ only)"
) +
theme_minimal(base_size = 11) +
theme(
panel.grid.major.y = element_blank(),
panel.grid.minor   = element_blank(),
axis.text.y = element_text(size = gene_axis_text_size,   face = "bold"),
axis.text.x = element_text(size = somite_axis_text_size, face = "bold"),
plot.title  = element_text(face = "bold")
)
}
p_hox_bar <- make_pcr_hox_bar(pcr_long_union)
ggsave(out_pcr_hox_bar_png, p_hox_bar, width = 10, height = 6, dpi = 1600)
