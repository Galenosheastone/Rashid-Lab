Norm  <- read_csv_quiet(norm_counts_path)  # rows = Geneid
ColD  <- read_csv_quiet(coldata_path)      # rownames in column 1
Annot <- read_csv_quiet(annot_path)
# Restore rownames
rownames(ColD) <- ColD[[1]]; ColD[[1]] <- NULL
rownames(Norm) <- Norm[[1]]; Norm[[1]] <- NULL
# Align samples
common_samples <- intersect(colnames(Norm), rownames(ColD))
if (length(common_samples) == 0) stop("No overlapping samples between normalized_counts and coldata.")
Norm <- Norm[, common_samples, drop=FALSE]
ColD <- ColD[common_samples, , drop=FALSE]
# Pick grouping column: prefer 'tissue', else 'region', else 'condition'
group_field <- if ("tissue" %in% colnames(ColD)) "tissue" else if ("region" %in% colnames(ColD)) "region" else "condition"
if (!group_field %in% colnames(ColD)) stop("No grouping column found. Need one of: tissue, region, condition in coldata.")
# -----------------------
# Map Geneid -> SYMBOL; resolve duplicates by highest mean expression
# -----------------------
if (!"Geneid" %in% colnames(Annot)) stop("gene_annotation_used.csv must contain 'Geneid'.")
if (!"SYMBOL" %in% colnames(Annot)) Annot$SYMBOL <- rownames(Annot)
Annot <- Annot[match(rownames(Norm), Annot$Geneid), c("Geneid","SYMBOL"), drop=FALSE]
Annot$SYMBOL <- ifelse(is.na(Annot$SYMBOL) | !nzchar(Annot$SYMBOL), Annot$Geneid, Annot$SYMBOL)
Annot$SYMBOL <- as.character(Annot$SYMBOL)
row_means <- rowMeans(Norm, na.rm = TRUE)
sym_best_idx <- tapply(seq_along(row_means), Annot$SYMBOL, function(ix) ix[which.max(row_means[ix])])
sym_best_idx <- unlist(sym_best_idx, use.names = TRUE)
Norm_sym <- Norm[sym_best_idx, , drop=FALSE]
rownames(Norm_sym) <- names(sym_best_idx)  # SYMBOLs as rownames
# -----------------------
# Verify HOX symbols present & select targets (HOX + GDF11)
# -----------------------
all_hox_like <- unique(grep("^HOX[ABCD]", Annot$SYMBOL, value = TRUE))
write.csv(data.frame(HOX_like_in_annotation = sort(all_hox_like)),
file.path(focus_rootdir, "FOCUS_all_HOX_like_SYMBOLS_in_annotation.csv"),
row.names = FALSE)
target_symbols <- grep(gene_regex, rownames(Norm_sym), value = TRUE, ignore.case = FALSE)
if (length(target_symbols) == 0) {
stop("No genes matched gene_regex = ", gene_regex,
" among SYMBOLs. If needed, relax the pattern or set include_antisense <- TRUE.")
}
# --- HOX meta (cluster/number flags) & robust ordering (no warnings)
is_hox   <- grepl("^HOX[ABCD][0-9]{1,2}", target_symbols)
cluster  <- ifelse(is_hox, substr(target_symbols, 4, 4),
ifelse(target_symbols == "GDF11", "GDF11", NA))
number   <- rep(NA_integer_, length(target_symbols))
num_str  <- sub("^HOX[ABCD]([0-9]{1,2}).*$", "\\1", target_symbols[is_hox])
suppressWarnings(number[is_hox] <- as.integer(num_str))
isGDF11  <- target_symbols == "GDF11"
hox_df <- data.frame(
SYMBOL  = target_symbols,
is_hox  = is_hox,
cluster = cluster,
number  = number,
isGDF11 = isGDF11,
stringsAsFactors = FALSE
)
# Log any HOX-like symbols we couldn't number (usually unusual aliases)
unparsed <- subset(hox_df, is_hox & is.na(number))
if (nrow(unparsed) > 0) {
write.csv(unparsed,
file.path(focus_rootdir, "FOCUS_HOX_unparsed_symbols.csv"),
row.names = FALSE)
}
# Order: cluster Aâ†’D, number 1â†’13, then put GDF11 last
cl_map  <- c(A=1, B=2, C=3, D=4)
ord_idx <- order(
ifelse(is.na(hox_df$cluster), 9L, unname(cl_map[hox_df$cluster])),
ifelse(is.na(hox_df$number), 99L, hox_df$number),
-as.integer(hox_df$isGDF11),
hox_df$SYMBOL
)
# Final targets & metadata in that order
target_symbols <- hox_df$SYMBOL[ord_idx]
hox_meta <- hox_df[ord_idx, c("SYMBOL","cluster","number","isGDF11")]
rownames(hox_meta) <- hox_meta$SYMBOL
# Subset counts to targets in that order
Norm_target <- Norm_sym[target_symbols, , drop=FALSE]
# Save picked symbols for traceability
write.csv(data.frame(selected_SYMBOLS = target_symbols),
file.path(focus_rootdir, "FOCUS_selected_SYMBOLS.csv"),
row.names = FALSE)
# -----------------------
# Heatmap (z-score by gene), samples ordered by group_field
# -----------------------
Z <- t(apply(Norm_target, 1, zscore))
ord_samples <- order(ColD[[group_field]])
Z <- Z[, ord_samples, drop=FALSE]
ann_col <- data.frame(group = ColD[[group_field]][ord_samples])
rownames(ann_col) <- colnames(Z)
pdf(file.path(focus_rootdir, "FOCUS_heatmap_HOX_plus_GDF11.pdf"), width = w_heat, height = h_heat)
pheatmap(Z,
annotation_col = ann_col,
clustering_method = "complete",
cluster_rows = FALSE,            # keep HOX order Aâ†’D, 1â†’13
show_colnames = FALSE,
main = paste0("HOX genes (+ GDF11) â€” z-scored normalized counts (group = ", group_field, ")"))
dev.off()
# -----------------------
# Violin + box + jitter per gene (by group_field)
# -----------------------
long <- as.data.frame(t(Norm_target))
long$sample <- rownames(long)
long <- merge(long,
data.frame(sample=rownames(ColD), group=ColD[[group_field]], check.names = FALSE),
by="sample")
melted <- reshape2::melt(long, id.vars = c("sample","group"),
variable.name = "SYMBOL", value.name = "normCount")
melted$SYMBOL <- factor(melted$SYMBOL, levels = target_symbols)
pdf(file.path(focus_rootdir, "FOCUS_violin_box_jitter_HOX_plus_GDF11.pdf"), width = w_violin, height = h_violin)
print(
ggplot(melted, aes(x = group, y = normCount)) +
geom_violin(trim = FALSE, alpha = 0.30) +
geom_boxplot(width = 0.15, outlier.shape = NA) +
geom_jitter(width = 0.15, alpha = 0.6, size = 1.6) +
facet_wrap(~ SYMBOL, scales = "free_y", ncol = 4) +
labs(title = paste0("Normalized counts by ", group_field, " â€” HOX genes (+ GDF11)"),
x = group_field, y = "Normalized counts") +
theme_bw(base_size = 12) +
theme(axis.text.x = element_text(angle = 30, hjust = 1))
)
dev.off()
# -----------------------
# Pull DE results across contrasts (by SYMBOL) and summarize targets
# -----------------------
all_sym_files <- list.files(deseq2_dir, pattern = "^DESeq2_.*_by_SYMBOL\\.csv$", full.names = TRUE)
de_table <- NULL
if (length(all_sym_files) > 0) {
stack_one <- function(f) {
df <- read.csv(f, check.names = FALSE)
rownames(df) <- df[[1]]; df[[1]] <- NULL
df$SYMBOL <- rownames(df)
label <- sub("^DESeq2_(.*)_by_SYMBOL\\.csv$", "\\1", basename(f))  # <A>_vs_<B>
df$contrast <- label
df
}
lst <- lapply(all_sym_files, stack_one)
de_table <- do.call(rbind, lst)
de_table <- de_table[de_table$SYMBOL %in% target_symbols, , drop=FALSE]
keep_cols <- intersect(colnames(de_table),
c("SYMBOL","contrast","baseMean","log2FC","log2FC_shrunken",
"lfcSE_shrunken","stat","pvalue","padj"))
de_table <- de_table[, keep_cols, drop=FALSE]
de_table$SYMBOL <- factor(de_table$SYMBOL, levels = target_symbols)
write.csv(de_table, file.path(focus_rootdir, "FOCUS_DE_summary_HOX_plus_GDF11_by_SYMBOL.csv"), row.names = FALSE)
}
# -----------------------
# Lollipop plot of log2FC across contrasts (padj color)
# -----------------------
if (!is.null(de_table) && nrow(de_table) > 0) {
if ("log2FC_shrunken" %in% colnames(de_table)) {
de_table$LFC <- de_table$log2FC_shrunken
} else if ("log2FC" %in% colnames(de_table)) {
de_table$LFC <- de_table$log2FC
} else {
de_table$LFC <- NA_real_
}
de_table$FDR <- de_table$padj
pdf(file.path(focus_rootdir, "FOCUS_lollipop_LFC_HOX_plus_GDF11.pdf"), width = w_lolli, height = h_lolli)
print(
ggplot(de_table, aes(x = contrast, y = LFC, group = SYMBOL, color = FDR < 0.05)) +
geom_hline(yintercept = 0, linetype = 2) +
geom_point(size = 2) +
geom_segment(aes(xend = contrast, y = 0, yend = LFC), linewidth = 0.5) +
facet_wrap(~ SYMBOL, ncol = 4, scales = "free_y") +
scale_color_manual(values = c("TRUE" = "#d73027", "FALSE" = "#1a9850"),
breaks = c("TRUE","FALSE"),
labels = c("FDR < 0.05","FDR â‰Ą 0.05")) +
labs(title = "Effect sizes across contrasts â€” HOX genes (+ GDF11)",
x = "Contrast", y = "log2 fold-change (shrunken if available)", color = "Significant") +
theme_bw(base_size = 12) +
theme(axis.text.x = element_text(angle = 40, hjust = 1))
)
dev.off()
}
# ================================================================
# NEW VISUALS
# ================================================================
# 1) Geneâ€“gene Pearson correlation heatmap (HOX+GDF11)
corr_mat <- tryCatch(cor(t(Norm_target), use = "pairwise.complete.obs", method = "pearson"),
error = function(e) NULL)
if (!is.null(corr_mat)) {
ann_row <- data.frame(cluster = hox_meta[colnames(corr_mat), "cluster"])
rownames(ann_row) <- colnames(corr_mat)
pdf(file.path(focus_rootdir, "FOCUS_corr_heatmap_HOX_plus_GDF11.pdf"), width = w_corr, height = h_corr)
pheatmap(corr_mat,
annotation_row = ann_row,
annotation_col = ann_row,
main = "Geneâ€“gene Pearson correlation â€” HOX (+ GDF11)")
dev.off()
}
# 2) Condition-level dot heatmap (mean expr per gene Ă— group)
group_vec <- ColD[colnames(Norm_target), group_field]
group_levels <- unique(as.character(group_vec))
Means_by_group <- sapply(group_levels, function(g) {
idx <- which(group_vec == g)
rowMeans(Norm_target[, idx, drop=FALSE], na.rm = TRUE)
})
Means_df <- as.data.frame(Means_by_group)
Means_df$SYMBOL <- rownames(Norm_target)
dot_df <- reshape2::melt(Means_df, id.vars = "SYMBOL",
variable.name = group_field, value.name = "meanExpr")
# z-score the means within each gene across groups for a good color scale
dot_df$zMean <- ave(dot_df$meanExpr, dot_df$SYMBOL, FUN = zscore)
dot_df$SYMBOL <- factor(dot_df$SYMBOL, levels = target_symbols)
write.csv(dot_df, file.path(focus_rootdir, "FOCUS_condition_means_HOX_plus_GDF11.csv"), row.names = FALSE)
pdf(file.path(focus_rootdir, "FOCUS_dot_heatmap_means_HOX_plus_GDF11.pdf"), width = w_dot, height = h_dot)
print(
ggplot(dot_df, aes_string(x = group_field, y = "SYMBOL")) +
geom_point(aes(size = meanExpr, fill = zMean), shape = 21, color = "black", alpha = 0.9) +
scale_fill_gradient2(low = "#2166ac", mid = "white", high = "#b2182b", midpoint = 0) +
scale_size_continuous(name = "Mean expr", guide = "legend") +
labs(title = paste0("Mean expression by ", group_field, " â€” HOX genes (+ GDF11)"),
x = group_field, y = "Gene (SYMBOL)", fill = "z-score") +
theme_bw(base_size = 11) +
theme(axis.text.x = element_text(angle = 30, hjust = 1))
)
dev.off()
# 3) HOX cluster scores (per-sample mean of HOXA/B/C/D), boxplots by group
clusters <- c("A","B","C","D")
cluster_scores <- lapply(clusters, function(cl) {
genes_cl <- rownames(Norm_target)[hox_meta[rownames(Norm_target), "cluster"] == cl]
if (length(genes_cl) == 0) return(NULL)
data.frame(
sample   = colnames(Norm_target),
cluster  = cl,
score    = colMeans(Norm_target[genes_cl, , drop=FALSE], na.rm = TRUE),
group    = as.character(ColD[colnames(Norm_target), group_field]),
stringsAsFactors = FALSE
)
})
cluster_scores <- do.call(rbind, cluster_scores)
if (!is.null(cluster_scores) && nrow(cluster_scores) > 0) {
write.csv(cluster_scores, file.path(focus_rootdir, "FOCUS_cluster_scores_per_sample.csv"), row.names = FALSE)
pdf(file.path(focus_rootdir, "FOCUS_cluster_scores_boxplots.pdf"), width = w_scores, height = h_scores)
print(
ggplot(cluster_scores, aes(x = group, y = score, fill = group)) +
geom_boxplot(outlier.shape = NA, alpha = 0.75) +
geom_jitter(width = 0.15, alpha = 0.6, size = 1.6) +
facet_wrap(~ cluster, nrow = 1, scales = "free_y") +
labs(title = paste0("HOX cluster scores by ", group_field, " (mean expr per sample)"),
x = group_field, y = "Cluster score (mean normalized expr)") +
theme_bw(base_size = 12) +
theme(legend.position = "none", axis.text.x = element_text(angle = 30, hjust = 1))
)
dev.off()
}
# 4) Positional HOX profiles (within each cluster: expression vs. HOX number), lines by group
pos_df <- do.call(rbind, lapply(clusters, function(cl) {
sub <- hox_meta[hox_meta$cluster == cl & !is.na(hox_meta$number), ]
if (!nrow(sub)) return(NULL)
genes <- sub$SYMBOL
tmp <- Norm_target[genes, , drop=FALSE]
# per-group mean at each HOX number
out <- lapply(group_levels, function(g) {
idx <- which(group_vec == g)
if (!length(idx)) return(NULL)
m <- rowMeans(tmp[, idx, drop=FALSE], na.rm = TRUE)
data.frame(cluster = cl, SYMBOL = names(m),
number = hox_meta[names(m), "number"],
group = g, meanExpr = as.numeric(m))
})
do.call(rbind, out)
}))
if (!is.null(pos_df) && nrow(pos_df) > 0) {
pdf(file.path(focus_rootdir, "FOCUS_positional_profiles_by_cluster.pdf"), width = w_pos, height = h_pos)
print(
ggplot(pos_df, aes(x = number, y = meanExpr, group = group, color = group)) +
geom_line(linewidth = 0.9, alpha = 0.9) +
geom_point(size = 1.8) +
facet_wrap(~ cluster, nrow = 2, scales = "free_y") +
scale_x_continuous(breaks = sort(unique(pos_df$number))) +
labs(title = paste0("Positional HOX profiles (mean expr by ", group_field, ")"),
x = "HOX number", y = "Mean normalized expression") +
theme_bw(base_size = 12)
)
dev.off()
}
# 5) GDF11 spotlight
if ("GDF11" %in% rownames(Norm_target)) {
gdf <- data.frame(
sample = colnames(Norm_target),
expr   = as.numeric(Norm_target["GDF11", ]),
group  = as.character(ColD[colnames(Norm_target), group_field]),
stringsAsFactors = FALSE
)
# One-way ANOVA across groups (if â‰Ą2 groups)
gdf_p <- NA
if (length(unique(gdf$group)) > 1) {
gdf_p <- tryCatch({
sm <- summary(aov(expr ~ group, data = gdf))
as.numeric(sm[[1]][["Pr(>F)"]][1])
}, error = function(e) NA_real_)
}
p_sub <- if (is.finite(gdf_p)) paste0("One-way ANOVA p = ", format(gdf_p, digits = 3)) else NULL
pdf(file.path(focus_rootdir, "FOCUS_GDF11_spotlight.pdf"), width = w_gdf, height = h_gdf)
print(
ggplot(gdf, aes(x = group, y = expr)) +
geom_violin(trim = FALSE, alpha = 0.30) +
geom_boxplot(width = 0.15, outlier.shape = NA) +
geom_jitter(width = 0.15, alpha = 0.7, size = 1.7) +
labs(title = "GDF11 expression across groups",
subtitle = p_sub,
x = group_field, y = "Normalized expression (GDF11)") +
theme_bw(base_size = 12) +
theme(axis.text.x = element_text(angle = 30, hjust = 1))
)
dev.off()
# Forest-style LFC for GDF11 across contrasts (with SE if available)
if (!is.null(de_table) && nrow(de_table) > 0) {
gdf_de <- subset(de_table, SYMBOL == "GDF11")
if (nrow(gdf_de) > 0) {
gdf_de$LFC <- if ("log2FC_shrunken" %in% colnames(gdf_de)) gdf_de$log2FC_shrunken else gdf_de$log2FC
gdf_de$SE  <- if ("lfcSE_shrunken" %in% colnames(gdf_de)) gdf_de$lfcSE_shrunken else NA_real_
gdf_de$lower <- gdf_de$LFC - 1.96 * gdf_de$SE
gdf_de$upper <- gdf_de$LFC + 1.96 * gdf_de$SE
pdf(file.path(focus_rootdir, "FOCUS_GDF11_LFC_forest.pdf"), width = 6.8, height = max(3.5, 0.35*nrow(gdf_de)+1.5))
print(
ggplot(gdf_de, aes(y = reorder(contrast, LFC), x = LFC)) +
geom_vline(xintercept = 0, linetype = 2) +
geom_errorbarh(aes(xmin = lower, xmax = upper), height = 0.2, alpha = 0.8, na.rm = TRUE) +
geom_point(size = 2) +
labs(title = "GDF11 log2FC across contrasts",
x = "log2FC (Â±1.96Â·SE)", y = "Contrast") +
theme_bw(base_size = 12)
)
dev.off()
}
}
}
# 6) Mini-volcano panels (HOX+GDF11 only), faceted by contrast
if (!is.null(de_table) && nrow(de_table) > 0) {
dt <- de_table
dt$LFC <- if ("log2FC_shrunken" %in% colnames(dt)) dt$log2FC_shrunken else dt$log2FC
dt$FDR <- dt$padj
dt$neglog10FDR <- -log10(pmax(dt$FDR, .Machine$double.xmin))
dt$is_sig <- dt$FDR < 0.05
dt$is_gdf <- dt$SYMBOL == "GDF11"
pdf(file.path(focus_rootdir, "FOCUS_mini_volcano_HOX_plus_GDF11.pdf"), width = w_vulc, height = h_vulc)
print(
ggplot(dt, aes(x = LFC, y = neglog10FDR)) +
geom_hline(yintercept = -log10(0.05), linetype = 2) +
geom_vline(xintercept = 0, linetype = 3) +
geom_point(aes(shape = is_gdf, alpha = is_sig), size = 1.8) +
scale_shape_manual(values = c(`FALSE` = 16, `TRUE` = 17), labels = c("HOX", "GDF11")) +
scale_alpha_manual(values = c(`FALSE` = 0.5, `TRUE` = 0.95), guide = "none") +
facet_wrap(~ contrast, scales = "free") +
labs(title = "Mini-volcano (HOX + GDF11 only)",
x = "log2FC (shrunken if available)", y = "-log10(FDR)", shape = "Gene") +
theme_bw(base_size = 12)
)
dev.off()
}
# ================================================================
# ADD-ONS
# ================================================================
# 11) Contrast summary tile heatmap (sign(LFC) * -log10(FDR))
if (!is.null(de_table) && nrow(de_table) > 0) {
dt <- de_table
dt$LFC <- if ("log2FC_shrunken" %in% colnames(dt)) dt$log2FC_shrunken else dt$log2FC
dt$score <- sign(dt$LFC) * (-log10(pmax(dt$padj, .Machine$double.xmin)))
keep <- as.character(unique(hox_meta$SYMBOL))
dt <- dt[dt$SYMBOL %in% keep, ]
dt$SYMBOL <- factor(dt$SYMBOL, levels = rownames(hox_meta))
pdf(file.path(focus_rootdir, "FOCUS_contrast_summary_tile.pdf"), width = 9, height = 6.5)
print(
ggplot(dt, aes(x = contrast, y = SYMBOL, fill = score)) +
geom_tile(color = "grey80") +
scale_fill_gradient2(low = "#2166ac", mid = "white", high = "#b2182b", midpoint = 0,
name = "sign(LFC)Â·-log10(FDR)") +
labs(title = "Across-contrast summary â€” HOX (+ GDF11)",
x = "Contrast", y = "Gene (SYMBOL)") +
theme_bw(base_size = 11) +
theme(axis.text.x = element_text(angle = 40, hjust = 1))
)
dev.off()
}
# 12) HOX Posteriorization Index (HPI) + HPI vs GDF11
hoxtab <- hox_meta[!is.na(hox_meta$number), ]
expr_hox <- Norm_target[hoxtab$SYMBOL, , drop=FALSE]
nums <- hoxtab$number; names(nums) <- hoxtab$SYMBOL
# Weighted mean HOX number per sample (correct orientation)
wexpr <- sweep(expr_hox, 1, nums[rownames(expr_hox)], "*")  # weight each gene (row)
num_hpi <- colSums(wexpr, na.rm = TRUE)
den_hpi <- pmax(colSums(expr_hox, na.rm = TRUE), .Machine$double.xmin)
hpi <- num_hpi / den_hpi
df_hpi <- data.frame(
sample = names(hpi),
HPI = as.numeric(hpi),
group = ColD[names(hpi), group_field],
stringsAsFactors = FALSE
)
pdf(file.path(focus_rootdir, "FOCUS_HOX_posteriorization_index.pdf"), width = 7, height = 4.8)
print(
ggplot(df_hpi, aes(x = group, y = HPI, fill = group)) +
geom_boxplot(outlier.shape = NA, alpha = 0.75) +
geom_jitter(width = 0.15, alpha = 0.6, size = 1.6) +
labs(title = paste0("HOX Posteriorization Index by ", group_field),
x = group_field, y = "Weighted mean HOX number") +
theme_bw(base_size = 12) + theme(legend.position = "none",
axis.text.x = element_text(angle = 30, hjust = 1))
)
dev.off()
write.csv(df_hpi, file.path(focus_rootdir, "FOCUS_HOX_posteriorization_index.csv"), row.names = FALSE)
if ("GDF11" %in% rownames(Norm_target)) {
gdf_vec <- as.numeric(Norm_target["GDF11", colnames(Norm_target)])
df_cor <- data.frame(HPI = df_hpi$HPI, GDF11 = gdf_vec, group = df_hpi$group)
r_all <- suppressWarnings(cor(df_cor$HPI, df_cor$GDF11, method = "pearson", use = "pair"))
pdf(file.path(focus_rootdir, "FOCUS_HPI_vs_GDF11_scatter.pdf"), width = 6.2, height = 4.8)
print(
ggplot(df_cor, aes(x = HPI, y = GDF11, color = group)) +
geom_point(size = 2, alpha = 0.9) +
geom_smooth(method = "lm", se = TRUE, linewidth = 0.8) +
labs(title = paste0("HPI vs GDF11 (r = ", sprintf("%.2f", r_all), ")"),
x = "HOX Posteriorization Index", y = "GDF11 normalized expr") +
theme_bw(base_size = 12)
)
dev.off()
}
# 13) PCA (and optional UMAP) on HOX+GDF11
X <- t(scale(t(Norm_target), center = TRUE, scale = TRUE))  # gene-wise z
pca <- prcomp(t(X), center = TRUE, scale. = FALSE)
pc <- as.data.frame(pca$x[, 1:3])
pc$sample <- rownames(pc)
pc$group  <- ColD[pc$sample, group_field]
pdf(file.path(focus_rootdir, "FOCUS_PCA_HOX_plus_GDF11_samples.pdf"), width = 6.6, height = 5.6)
print(
ggplot(pc, aes(x = PC1, y = PC2, color = group)) +
geom_point(size = 2.2, alpha = 0.95) +
labs(title = "PCA â€” HOX (+ GDF11) sample space", x = "PC1", y = "PC2") +
theme_bw(base_size = 12)
)
dev.off()
# Optional UMAP (auto-tune neighbors; skip if too few samples)
if (!requireNamespace("uwot", quietly = TRUE)) {
try(install.packages("uwot"))
}
if (requireNamespace("uwot", quietly = TRUE)) {
n_samples <- ncol(X)  # samples are columns
if (n_samples >= 3) {
nn <- max(2, min(10, n_samples - 1))
set.seed(42)
um <- uwot::umap(t(X), n_neighbors = nn, min_dist = 0.3, metric = "cosine")
umdf <- data.frame(UMAP1 = um[,1], UMAP2 = um[,2], sample = colnames(X))
umdf$group <- ColD[umdf$sample, group_field]
pdf(file.path(focus_rootdir, "FOCUS_UMAP_HOX_plus_GDF11_samples.pdf"), width = 6.6, height = 5.6)
print(
ggplot(umdf, aes(x = UMAP1, y = UMAP2, color = group)) +
geom_point(size = 2.2, alpha = 0.95) +
labs(title = paste0("UMAP â€” HOX (+ GDF11) sample space (n_neighbors=", nn, ")"),
x = "UMAP1", y = "UMAP2") +
theme_bw(base_size = 12)
)
dev.off()
} else {
message("Skipping UMAP: need at least 3 samples (have ", n_samples, ").")
}
}
# 14) GDF11 vs HOX cluster scores (scatter) + r/p table
if (!is.null(cluster_scores) && nrow(cluster_scores) > 0 && "GDF11" %in% rownames(Norm_target)) {
gdf_vec <- data.frame(sample = colnames(Norm_target),
GDF11 = as.numeric(Norm_target["GDF11", colnames(Norm_target)]))
cs <- merge(cluster_scores, gdf_vec, by = "sample")
get_rp <- function(x, y) {
ct <- tryCatch(cor.test(x, y, method="pearson"), error = function(e) NULL)
if (is.null(ct)) return(c(NA, NA))
c(unname(ct$estimate), unname(ct$p.value))
}
rp_list <- lapply(split(cs, cs$cluster), function(dd) get_rp(dd$score, dd$GDF11))
rp <- do.call(rbind, rp_list)
rp <- data.frame(cluster = rownames(rp), r = rp[,1], p = rp[,2])
pdf(file.path(focus_rootdir, "FOCUS_GDF11_vs_cluster_scores.pdf"), width = 8, height = 5.2)
print(
ggplot(cs, aes(x = score, y = GDF11, color = group)) +
geom_point(size = 2, alpha = 0.9) +
geom_smooth(method = "lm", se = TRUE, linewidth = 0.8) +
facet_wrap(~ cluster, scales = "free") +
labs(title = "GDF11 vs HOX cluster scores",
x = "Cluster score (mean normalized expr)", y = "GDF11 normalized expr") +
theme_bw(base_size = 12)
)
dev.off()
write.csv(rp, file.path(focus_rootdir, "FOCUS_GDF11_cluster_correlations.csv"), row.names = FALSE)
}
